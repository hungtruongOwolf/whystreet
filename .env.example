# === WhyStreet — environment variables ===
# Copy this file to .env and fill in the real values. Do NOT commit .env.

# --- RocketRide Cloud (REQUIRED) ---
# Always use https:// — http/bare host downgrades to unencrypted.
ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_AUTH=            # API token from cloud.rocketride.ai (shown only once when generated)

# --- Linkup (REQUIRED) ---
LINKUP_API_KEY=            # from app.linkup.so

# --- Supabase ---
SUPABASE_URL=              # Project URL, e.g. https://xxxx.supabase.co
SUPABASE_ANON_KEY=         # anon public key (used by the frontend)
SUPABASE_SERVICE_KEY=      # service_role key (used by the seed script — KEEP SECRET)

# --- Detector / realtime (tunable) ---
ZSCORE_THRESHOLD=2.5       # shock-detection threshold (keep high for realtime to avoid noise)
POLL_INTERVAL_MIN=10       # minutes between realtime scheduler scans

# --- Frontend (Vite needs the VITE_ prefix to expose to the client) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=/api

# Neo4j Aura (free) — causal knowledge graph + in-pipeline graph-RAG (db_neo4j)
ROCKETRIDE_NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
ROCKETRIDE_NEO4J_USER=neo4j
ROCKETRIDE_NEO4J_PASSWORD=your-aura-password

GRAPHRAG_PRIORS=off
